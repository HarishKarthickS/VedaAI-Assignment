# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# API
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/vedaai
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-a-long-access-secret-value
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret-value
COOKIE_DOMAIN=

# OpenRouter is required for actual assessment generation.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=VedaAI

# UploadThing must allow overriding ACL because study files and PDF exports are private.
UPLOADTHING_TOKEN=

# Optional operational integrations
SENTRY_DSN=
LOG_LEVEL=info
